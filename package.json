{
  "name": "craftfolio",
  "private": false,
  "version": "1.0.3",
  "description": "Craftfolio — a drop-in React component that renders a complete Minecraft-themed developer portfolio from your own data, with live 3D voxel worlds.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "react",
    "portfolio",
    "minecraft",
    "craftfolio",
    "theme",
    "three",
    "voxel",
    "components",
    "developer-portfolio"
  ],
  "author": "Craftfolio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tech-aficionado/CraftFolio---Open-Sourced-Minecraft-Portfolio-Library.git"
  },
  "bugs": {
    "url": "https://github.com/Tech-aficionado/CraftFolio---Open-Sourced-Minecraft-Portfolio-Library/issues"
  },
  "homepage": "https://github.com/Tech-aficionado/CraftFolio---Open-Sourced-Minecraft-Portfolio-Library#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "framer-motion": "^11.3.19",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-plugin-dts": "^4.2.1"
  }
}
